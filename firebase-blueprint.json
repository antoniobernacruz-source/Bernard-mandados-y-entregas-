{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user (Client or Driver)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "driver", "admin"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Delivery or errand request",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "clientId": { "type": "string" },
        "driverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "picked_up", "delivered", "cancelled"] },
        "type": { "type": "string", "enum": ["delivery", "errand"] },
        "description": { "type": "string" },
        "origin": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "destination": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "price": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card", "transfer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "status", "type", "description"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles and metadata"
    },
    "orders": {
      "schema": "Order",
      "description": "Errand and delivery orders"
    }
  }
}
